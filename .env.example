# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL username (required)
POSTGRES_USER=nutrilabs

# PostgreSQL password — choose a strong value (required)
POSTGRES_PASSWORD=changeme

# PostgreSQL database name (required)
POSTGRES_DB=nutrilabs

# Full connection string used by Prisma. Format: postgresql://user:password@postgres:5432/dbname
# The host "postgres" matches the Docker Compose service name (required)
DATABASE_URL=postgresql://nutrilabs:changeme@postgres:5432/nutrilabs

# ─── Auth ────────────────────────────────────────────────────────────────────
# Long random string used to sign JWT tokens — generate with: openssl rand -hex 64 (required)
JWT_SECRET=change-me-to-a-long-random-string

# ─── Ollama (AI features) ────────────────────────────────────────────────────
# LAN IP and port of the machine running Ollama, e.g. http://192.168.1.190:11434 (required for AI)
OLLAMA_HOST=http://192.168.1.190:11434

# Ollama model name to use for AI features, e.g. llama3 (required for AI)
OLLAMA_MODEL=llama3

# ─── Kroger API (optional — grocery pricing) ─────────────────────────────────
# OAuth client ID from developer.kroger.com — leave blank to disable Kroger integration
KROGER_CLIENT_ID=

# OAuth client secret from developer.kroger.com — leave blank to disable Kroger integration
KROGER_CLIENT_SECRET=

# ─── Spoonacular (optional — external recipe search) ─────────────────────────
# API key from spoonacular.com/food-api/console — leave blank to disable (150 req/day on free tier)
SPOONACULAR_API_KEY=

# ─── USDA FoodData Central (optional — ingredient nutrition lookup) ───────────
# API key from fdc.nal.usda.gov/api-key-signup.html
# Leave blank to use the DEMO_KEY fallback (rate-limited to 30 req/hr)
USDA_API_KEY=

# ─── SMTP (optional — required for password reset emails) ────────────────────
# SMTP server hostname, e.g. smtp.resend.com or smtp.gmail.com
SMTP_HOST=

# SMTP port: 587 for STARTTLS (recommended), 465 for SSL
SMTP_PORT=587

# SMTP username or email address
SMTP_USER=

# SMTP password, app password, or API key (e.g. Resend API key)
SMTP_PASSWORD=

# The From address used when sending emails, e.g. nutrilabs@yourdomain.com
SMTP_FROM_ADDRESS=

# Display name shown in the From field (default: NutriLabs)
SMTP_FROM_NAME=NutriLabs

# Full public URL of your app — used to build password reset links
# Note: SMTP settings can also be configured in Settings > Connections > Email in the UI.
# Values set in the UI take precedence over these environment variables.
# Examples: http://localhost:1042  or  https://nutrilabs.nexmolab.us
APP_BASE_URL=http://localhost:1042

# ─── App ─────────────────────────────────────────────────────────────────────
# Node environment: development or production (required)
NODE_ENV=production

# Public base URL of the app, used for cookies and CORS (required)
# Examples: http://localhost:1042  or  https://nutrilabs.nexmolab.us
BASE_URL=http://localhost:1042

# ─── Cloudflare (optional — for cache purging on deploy) ─────────────────────
# Zone ID from dash.cloudflare.com — leave blank if not using Cloudflare
CF_ZONE_ID=

# API token with Cache Purge permission — leave blank if not using Cloudflare
CF_API_TOKEN=
